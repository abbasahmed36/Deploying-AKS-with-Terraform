# --- Terraform directories & local state (never commit) ---
**/.terraform/*
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info
crash.log
crash.*.log

# Override files
override.tf
override.tf.json

# Vars (ignore if they may contain secrets; commit *.example instead)
*.tfvars
*.tfvars.json
# terraform.tfvars  # leave ignored unless sanitized

# Plans
*.plan
tfplan
tfplan.out

# Backend config (generated)
**/backend.hcl
!**/backend.example.hcl

# Remote-state local state file
remote-state/terraform.tfstate

# Local env / credentials
terraform.env
.env
*.env

# DO COMMIT provider lockfiles (remove this from ignore if present)
# .terraform.lock.hcl  <-- ensure this is NOT ignored

